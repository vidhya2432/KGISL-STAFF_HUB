{
  "entities": {
    "Class": {
      "title": "Class",
      "description": "Represents a group or section handled by a faculty member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "The label for the class (e.g., Grade 10-A)." },
        "facultyId": { "type": "string" }
      },
      "required": ["id", "name", "facultyId"]
    },
    "Student": {
      "title": "Student",
      "description": "A student profile within a specific class.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "roll": { "type": "string" }
      },
      "required": ["id", "name", "roll"]
    },
    "TimetableEntry": {
      "title": "Timetable Entry",
      "description": "A specific scheduled class for a class group.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "day": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"] },
        "time": { "type": "string", "description": "Time slot (e.g., 10:00 - 11:30)." },
        "course": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["id", "classId", "day", "time", "course"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "An assignment task created for a specific class.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "grouping": { "type": "string", "enum": ["Individual", "Team"] },
        "teamSize": { "type": "number" },
        "mappings": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "assigneeName": { "type": "string" },
              "assigneeId": { "type": "string" },
              "topic": { "type": "string" }
            }
          }
        },
        "dueDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "classId", "title", "dueDate"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A student's submission for an assignment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "rollNumber": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "marks": { "type": "number" },
        "plagiarismScore": { "type": "number" },
        "status": { "type": "string", "enum": ["Submitted", "Pending", "Late"] }
      },
      "required": ["id", "assignmentId", "studentId"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Collection of classes managed by faculty."
    },
    "/classes/{classId}/students/{studentId}": {
      "schema": "Student",
      "description": "Roster of students for a specific class."
    },
    "/classes/{classId}/schedule/{entryId}": {
      "schema": "TimetableEntry",
      "description": "Timetable entries for a specific class."
    },
    "/classes/{classId}/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Assignments for a specific class."
    },
    "/classes/{classId}/assignments/{assignmentId}/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student submissions for an assignment."
    }
  }
}